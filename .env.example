# 张雪峰 AI Agent 环境变量

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL=gpt-4o-mini

# Redis（本地开发用 localhost，Fly.io 部署用 Upstash）
REDIS_URL=redis://localhost:6379/0
# Upstash Redis（Fly.io 部署）：
# REDIS_URL=rediss://default:<password>@<host>:<port>

# 数据库
DATABASE_URL=sqlite:///./data/zhangxuefeng.db

# 应用
DEBUG=false
SKILL_PATH=SKILL.md

# Sentry（错误追踪）
SENTRY_DSN=

# 成本预警阈值（USD）
COST_ALERT_THRESHOLD_USD=50.0

# CORS（逗号分隔）
CORS_ORIGINS=*
